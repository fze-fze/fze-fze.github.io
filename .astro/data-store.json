[["Map",1,2,9,10,161,162],"meta::meta",["Map",3,4,5,6,7,8],"astro-version","5.18.1","content-config-digest","70bef62f63ebab4d","astro-config-digest","{\"root\":{},\"srcDir\":{},\"publicDir\":{},\"outDir\":{},\"cacheDir\":{},\"site\":\"https://example.com\",\"compressHTML\":true,\"base\":\"/\",\"trailingSlash\":\"ignore\",\"output\":\"static\",\"scopedStyleStrategy\":\"attribute\",\"build\":{\"format\":\"directory\",\"client\":{},\"server\":{},\"assets\":\"_astro\",\"serverEntry\":\"entry.mjs\",\"redirects\":true,\"inlineStylesheets\":\"auto\",\"concurrency\":1},\"server\":{\"open\":false,\"host\":false,\"port\":4321,\"streaming\":true,\"allowedHosts\":[]},\"redirects\":{},\"image\":{\"endpoint\":{\"route\":\"/_image\"},\"service\":{\"entrypoint\":\"astro/assets/services/sharp\",\"config\":{}},\"domains\":[],\"remotePatterns\":[],\"responsiveStyles\":false},\"devToolbar\":{\"enabled\":true},\"markdown\":{\"syntaxHighlight\":{\"type\":\"shiki\",\"excludeLangs\":[\"math\"]},\"shikiConfig\":{\"langs\":[],\"langAlias\":{},\"theme\":\"github-dark\",\"themes\":{},\"wrap\":false,\"transformers\":[]},\"remarkPlugins\":[],\"rehypePlugins\":[],\"remarkRehype\":{},\"gfm\":true,\"smartypants\":true},\"security\":{\"checkOrigin\":true,\"allowedDomains\":[],\"actionBodySizeLimit\":1048576},\"env\":{\"schema\":{},\"validateSecrets\":false},\"experimental\":{\"clientPrerender\":false,\"contentIntellisense\":false,\"headingIdCompat\":false,\"preserveScriptOrder\":false,\"liveContentCollections\":false,\"csp\":false,\"staticImportMetaEnv\":false,\"chromeDevtoolsWorkspace\":false,\"failOnPrerenderConflict\":false,\"svgo\":false},\"legacy\":{\"collections\":false}}","articles",["Map",11,12,44,45,69,70,100,101,131,132],"modern-writing-surface",{"id":11,"data":13,"body":22,"filePath":23,"digest":24,"rendered":25,"legacyId":43},{"title":14,"description":15,"date":16,"tags":17,"draft":21},"用未来感界面做内容整理，不只是“好看”","一个博客的视觉系统，应该帮助内容被更清晰地理解，而不是只停留在风格层面。",["Date","2026-03-20T00:00:00.000Z"],[18,19,20],"设计系统","内容产品","Astro",false,"## 为什么这个博客不走传统卡片流\n\n很多博客模板默认会把内容拆成一排排卡片，但对于长期写作来说，那更像是“信息售卖货架”，而不是一个能沉淀判断的空间。\n\n我更想要的是一种有秩序的界面感：\n\n- 首页像一张海报，先传达气质与方向\n- 文章列表像一组安静的信号面板，而不是营销组件\n- 正文页保持高可读性，让内容真正站住\n\n## 内容与界面应该怎么分工\n\n内容负责提供观点、结构和节奏，界面负责：\n\n1. 让入口更明确\n2. 让阅读更舒适\n3. 让归档更容易维护\n\n如果 UI 很强，但新增一篇文章需要改三处文件，那它就不是一个真正好的博客系统。\n\n## 为什么选 Astro\n\nAstro 的内容集合很适合这种需求：\n\n- Markdown 是一等公民\n- frontmatter 可以做类型校验\n- 静态输出很干净\n- 页面和内容可以自然解耦\n\n这意味着我可以专注于写作本身，而不是被后台系统和运行时复杂度拖住。","src/content/articles/modern-writing-surface.md","4d6d0c808c340a25",{"html":26,"metadata":27},"\u003Ch2 id=\"为什么这个博客不走传统卡片流\">为什么这个博客不走传统卡片流\u003C/h2>\n\u003Cp>很多博客模板默认会把内容拆成一排排卡片，但对于长期写作来说，那更像是“信息售卖货架”，而不是一个能沉淀判断的空间。\u003C/p>\n\u003Cp>我更想要的是一种有秩序的界面感：\u003C/p>\n\u003Cul>\n\u003Cli>首页像一张海报，先传达气质与方向\u003C/li>\n\u003Cli>文章列表像一组安静的信号面板，而不是营销组件\u003C/li>\n\u003Cli>正文页保持高可读性，让内容真正站住\u003C/li>\n\u003C/ul>\n\u003Ch2 id=\"内容与界面应该怎么分工\">内容与界面应该怎么分工\u003C/h2>\n\u003Cp>内容负责提供观点、结构和节奏，界面负责：\u003C/p>\n\u003Col>\n\u003Cli>让入口更明确\u003C/li>\n\u003Cli>让阅读更舒适\u003C/li>\n\u003Cli>让归档更容易维护\u003C/li>\n\u003C/ol>\n\u003Cp>如果 UI 很强，但新增一篇文章需要改三处文件，那它就不是一个真正好的博客系统。\u003C/p>\n\u003Ch2 id=\"为什么选-astro\">为什么选 Astro\u003C/h2>\n\u003Cp>Astro 的内容集合很适合这种需求：\u003C/p>\n\u003Cul>\n\u003Cli>Markdown 是一等公民\u003C/li>\n\u003Cli>frontmatter 可以做类型校验\u003C/li>\n\u003Cli>静态输出很干净\u003C/li>\n\u003Cli>页面和内容可以自然解耦\u003C/li>\n\u003C/ul>\n\u003Cp>这意味着我可以专注于写作本身，而不是被后台系统和运行时复杂度拖住。\u003C/p>",{"headings":28,"localImagePaths":37,"remoteImagePaths":38,"frontmatter":39,"imagePaths":42},[29,32,34],{"depth":30,"slug":31,"text":31},2,"为什么这个博客不走传统卡片流",{"depth":30,"slug":33,"text":33},"内容与界面应该怎么分工",{"depth":30,"slug":35,"text":36},"为什么选-astro","为什么选 Astro",[],[],{"title":14,"description":15,"date":40,"tags":41,"draft":21},["Date","2026-03-20T00:00:00.000Z"],[18,19,20],[],"modern-writing-surface.md","template",{"id":44,"data":46,"body":53,"filePath":54,"digest":55,"rendered":56,"legacyId":68},{"title":47,"description":48,"date":49,"tags":50,"draft":52},"这里填写文章标题","用一句话概括文章内容，后续会出现在首页和文章列表。",["Date","2026-03-22T00:00:00.000Z"],[51],"示例标签",true,"## 开头\n\n从这里开始写正文。","src/content/articles/template.md","55543d002c301724",{"html":57,"metadata":58},"\u003Ch2 id=\"开头\">开头\u003C/h2>\n\u003Cp>从这里开始写正文。\u003C/p>",{"headings":59,"localImagePaths":62,"remoteImagePaths":63,"frontmatter":64,"imagePaths":67},[60],{"depth":30,"slug":61,"text":61},"开头",[],[],{"title":47,"description":48,"date":65,"tags":66,"draft":52},["Date","2026-03-22T00:00:00.000Z"],[51],[],"template.md","weekly-system-notes",{"id":69,"data":71,"body":79,"filePath":80,"digest":81,"rendered":82,"legacyId":99},{"title":72,"description":73,"date":74,"tags":75,"draft":21},"每周计划为什么值得单独成为一个板块","周计划不是任务软件的替代品，它更像公开的节奏记录器，帮助我看见自己真正投入了什么。",["Date","2026-03-18T00:00:00.000Z"],[76,77,78],"周计划","工作流","复盘","## 把一周写出来，本身就是校准\n\n当我把“这周想做什么”写成公开的结构时，我会更快发现：\n\n- 目标是不是太散\n- 进度是不是只有忙碌，没有推进\n- 哪些事情应该继续，哪些事情应该停掉\n\n## 它和待办清单的区别\n\n待办清单通常回答“我要做什么”，而每周计划更适合回答：\n\n- 这周最重要的重点是什么\n- 为什么它值得投入\n- 本周结束后，我对自己的节奏有什么判断\n\n## 一个更容易长期坚持的模板\n\n我希望每篇计划都保持类似结构：\n\n1. 本周目标\n2. 推进中的事项\n3. 已经完成的部分\n4. 复盘与下周衔接\n\n结构越稳定，维护成本越低，也越容易回头看见变化。","src/content/articles/weekly-system-notes.md","9dc48558cbfe6d19",{"html":83,"metadata":84},"\u003Ch2 id=\"把一周写出来本身就是校准\">把一周写出来，本身就是校准\u003C/h2>\n\u003Cp>当我把“这周想做什么”写成公开的结构时，我会更快发现：\u003C/p>\n\u003Cul>\n\u003Cli>目标是不是太散\u003C/li>\n\u003Cli>进度是不是只有忙碌，没有推进\u003C/li>\n\u003Cli>哪些事情应该继续，哪些事情应该停掉\u003C/li>\n\u003C/ul>\n\u003Ch2 id=\"它和待办清单的区别\">它和待办清单的区别\u003C/h2>\n\u003Cp>待办清单通常回答“我要做什么”，而每周计划更适合回答：\u003C/p>\n\u003Cul>\n\u003Cli>这周最重要的重点是什么\u003C/li>\n\u003Cli>为什么它值得投入\u003C/li>\n\u003Cli>本周结束后，我对自己的节奏有什么判断\u003C/li>\n\u003C/ul>\n\u003Ch2 id=\"一个更容易长期坚持的模板\">一个更容易长期坚持的模板\u003C/h2>\n\u003Cp>我希望每篇计划都保持类似结构：\u003C/p>\n\u003Col>\n\u003Cli>本周目标\u003C/li>\n\u003Cli>推进中的事项\u003C/li>\n\u003Cli>已经完成的部分\u003C/li>\n\u003Cli>复盘与下周衔接\u003C/li>\n\u003C/ol>\n\u003Cp>结构越稳定，维护成本越低，也越容易回头看见变化。\u003C/p>",{"headings":85,"localImagePaths":93,"remoteImagePaths":94,"frontmatter":95,"imagePaths":98},[86,89,91],{"depth":30,"slug":87,"text":88},"把一周写出来本身就是校准","把一周写出来，本身就是校准",{"depth":30,"slug":90,"text":90},"它和待办清单的区别",{"depth":30,"slug":92,"text":92},"一个更容易长期坚持的模板",[],[],{"title":72,"description":73,"date":96,"tags":97,"draft":21},["Date","2026-03-18T00:00:00.000Z"],[76,77,78],[],"weekly-system-notes.md","notes-on-layout-rhythm",{"id":100,"data":102,"body":110,"filePath":111,"digest":112,"rendered":113,"legacyId":130},{"title":103,"description":104,"date":105,"tags":106,"draft":21},"写给自己的版式节奏笔记","当一个首页承担第一印象时，真正重要的不是装饰，而是每一层内容在视线里的进入顺序。",["Date","2026-03-16T00:00:00.000Z"],[107,108,109],"版式","设计","首页","## 为什么首页节奏这么重要\n\n首屏不是把所有内容都展示出来，而是决定用户第一眼先看见什么。\n\n如果标题、图像、入口、下方内容同时争抢注意力，首页就会变成一个没有重点的画板。\n\n## 我想保留的顺序\n\n1. 先让气质成立\n2. 再让内容入口出现\n3. 然后让阅读流自然展开\n\n## 这也是为什么我喜欢 sticky storytelling\n\n它不是炫技，而是把阅读顺序做得更明确。","src/content/articles/notes-on-layout-rhythm.md","fdd20e306f3d73ea",{"html":114,"metadata":115},"\u003Ch2 id=\"为什么首页节奏这么重要\">为什么首页节奏这么重要\u003C/h2>\n\u003Cp>首屏不是把所有内容都展示出来，而是决定用户第一眼先看见什么。\u003C/p>\n\u003Cp>如果标题、图像、入口、下方内容同时争抢注意力，首页就会变成一个没有重点的画板。\u003C/p>\n\u003Ch2 id=\"我想保留的顺序\">我想保留的顺序\u003C/h2>\n\u003Col>\n\u003Cli>先让气质成立\u003C/li>\n\u003Cli>再让内容入口出现\u003C/li>\n\u003Cli>然后让阅读流自然展开\u003C/li>\n\u003C/ol>\n\u003Ch2 id=\"这也是为什么我喜欢-sticky-storytelling\">这也是为什么我喜欢 sticky storytelling\u003C/h2>\n\u003Cp>它不是炫技，而是把阅读顺序做得更明确。\u003C/p>",{"headings":116,"localImagePaths":124,"remoteImagePaths":125,"frontmatter":126,"imagePaths":129},[117,119,121],{"depth":30,"slug":118,"text":118},"为什么首页节奏这么重要",{"depth":30,"slug":120,"text":120},"我想保留的顺序",{"depth":30,"slug":122,"text":123},"这也是为什么我喜欢-sticky-storytelling","这也是为什么我喜欢 sticky storytelling",[],[],{"title":103,"description":104,"date":127,"tags":128,"draft":21},["Date","2026-03-16T00:00:00.000Z"],[107,108,109],[],"notes-on-layout-rhythm.md","product-notes-in-public",{"id":131,"data":133,"body":141,"filePath":142,"digest":143,"rendered":144,"legacyId":160},{"title":134,"description":135,"date":136,"tags":137,"draft":21},"公开记录产品想法的好处","把想法写出来，会迫使自己把模糊感拆成结构，也更容易回头检查那些看似正确的直觉。",["Date","2026-03-14T00:00:00.000Z"],[138,139,140],"产品","写作","公开记录","## 公开记录不是为了显得勤奋\n\n更重要的是，它会留下判断的轨迹。\n\n## 当想法被写下来以后\n\n- 哪些是真的重要，会更快浮出来\n- 哪些只是情绪上的兴奋，也会慢慢暴露\n\n## 所以我想保留这个板块\n\n它像一个公开的思考缓存区，帮我看见自己到底在往哪里走。","src/content/articles/product-notes-in-public.md","e8c51a822df3a982",{"html":145,"metadata":146},"\u003Ch2 id=\"公开记录不是为了显得勤奋\">公开记录不是为了显得勤奋\u003C/h2>\n\u003Cp>更重要的是，它会留下判断的轨迹。\u003C/p>\n\u003Ch2 id=\"当想法被写下来以后\">当想法被写下来以后\u003C/h2>\n\u003Cul>\n\u003Cli>哪些是真的重要，会更快浮出来\u003C/li>\n\u003Cli>哪些只是情绪上的兴奋，也会慢慢暴露\u003C/li>\n\u003C/ul>\n\u003Ch2 id=\"所以我想保留这个板块\">所以我想保留这个板块\u003C/h2>\n\u003Cp>它像一个公开的思考缓存区，帮我看见自己到底在往哪里走。\u003C/p>",{"headings":147,"localImagePaths":154,"remoteImagePaths":155,"frontmatter":156,"imagePaths":159},[148,150,152],{"depth":30,"slug":149,"text":149},"公开记录不是为了显得勤奋",{"depth":30,"slug":151,"text":151},"当想法被写下来以后",{"depth":30,"slug":153,"text":153},"所以我想保留这个板块",[],[],{"title":134,"description":135,"date":157,"tags":158,"draft":21},["Date","2026-03-14T00:00:00.000Z"],[138,139,140],[],"product-notes-in-public.md","plans",["Map",163,164,44,200],"2026-week-12",{"id":163,"data":165,"body":177,"filePath":178,"digest":179,"rendered":180,"legacyId":199},{"title":166,"week":167,"status":168,"summary":169,"goals":170,"review":174,"draft":21},"第 12 周计划 / 让博客真正成为长期系统","2026 · Week 12","active","先把博客底层结构、视觉系统和内容维护体验做顺，再决定后续要不要加标签、搜索和部署流程。",[171,172,173],"完成 Astro 静态博客的结构搭建","建立统一的科技感视觉系统","写清 README，降低后续维护门槛",[175,176],"优先把内容源稳定下来，而不是过早追求花哨功能","页面数量不多，但每个页面都需要保持统一气质","## 本周目标\n\n- 完成首页、文章、每周计划三个主板块\n- 让 Markdown 成为日常更新的唯一入口\n- 为后续扩展保留足够清晰的目录结构\n\n## 推进中\n\n- 调整首页 hero，让它更接近“未来编辑台”的感觉\n- 统一列表页和详情页的光晕、模糊、边框语言\n- 整理 README，把内容新增流程写得更顺手\n\n## 已完成\n\n- 内容模型已经拆成 `articles` 和 `plans`\n- 页面路由已经按静态博客方式规划清楚\n- 每周计划改成“公开记录页”，而不是复杂任务看板\n\n## 复盘 / 下周衔接\n\n下一步会看三件事：\n\n1. 是否需要加入标签页\n2. 是否要补一套封面图规范\n3. 是否接入自动部署","src/content/plans/2026-week-12.md","8a6b17f44a4269d8",{"html":181,"metadata":182},"\u003Ch2 id=\"本周目标\">本周目标\u003C/h2>\n\u003Cul>\n\u003Cli>完成首页、文章、每周计划三个主板块\u003C/li>\n\u003Cli>让 Markdown 成为日常更新的唯一入口\u003C/li>\n\u003Cli>为后续扩展保留足够清晰的目录结构\u003C/li>\n\u003C/ul>\n\u003Ch2 id=\"推进中\">推进中\u003C/h2>\n\u003Cul>\n\u003Cli>调整首页 hero，让它更接近“未来编辑台”的感觉\u003C/li>\n\u003Cli>统一列表页和详情页的光晕、模糊、边框语言\u003C/li>\n\u003Cli>整理 README，把内容新增流程写得更顺手\u003C/li>\n\u003C/ul>\n\u003Ch2 id=\"已完成\">已完成\u003C/h2>\n\u003Cul>\n\u003Cli>内容模型已经拆成 \u003Ccode>articles\u003C/code> 和 \u003Ccode>plans\u003C/code>\u003C/li>\n\u003Cli>页面路由已经按静态博客方式规划清楚\u003C/li>\n\u003Cli>每周计划改成“公开记录页”，而不是复杂任务看板\u003C/li>\n\u003C/ul>\n\u003Ch2 id=\"复盘--下周衔接\">复盘 / 下周衔接\u003C/h2>\n\u003Cp>下一步会看三件事：\u003C/p>\n\u003Col>\n\u003Cli>是否需要加入标签页\u003C/li>\n\u003Cli>是否要补一套封面图规范\u003C/li>\n\u003Cli>是否接入自动部署\u003C/li>\n\u003C/ol>",{"headings":183,"localImagePaths":193,"remoteImagePaths":194,"frontmatter":195,"imagePaths":198},[184,186,188,190],{"depth":30,"slug":185,"text":185},"本周目标",{"depth":30,"slug":187,"text":187},"推进中",{"depth":30,"slug":189,"text":189},"已完成",{"depth":30,"slug":191,"text":192},"复盘--下周衔接","复盘 / 下周衔接",[],[],{"title":166,"week":167,"status":168,"summary":169,"goals":196,"review":197,"draft":21},[171,172,173],[175,176],[],"2026-week-12.md",{"id":44,"data":201,"body":213,"filePath":214,"digest":215,"rendered":216,"legacyId":68},{"title":202,"week":203,"status":204,"summary":205,"goals":206,"review":210,"draft":52},"第 X 周计划 / 这里填写本周主题","2026 · Week XX","planned","用一两句话概括这周最核心的目标和判断。",[207,208,209],"目标一","目标二","目标三",[211,212],"这里写本周复盘","这里写下周衔接","## 本周目标\n\n- \n\n## 推进中\n\n- \n\n## 已完成\n\n- \n\n## 复盘 / 下周衔接\n\n-","src/content/plans/template.md","29e02f75f6ec8721",{"html":217,"metadata":218},"\u003Ch2 id=\"本周目标\">本周目标\u003C/h2>\n\u003Cul>\n\u003Cli>\u003C/li>\n\u003C/ul>\n\u003Ch2 id=\"推进中\">推进中\u003C/h2>\n\u003Cul>\n\u003Cli>\u003C/li>\n\u003C/ul>\n\u003Ch2 id=\"已完成\">已完成\u003C/h2>\n\u003Cul>\n\u003Cli>\u003C/li>\n\u003C/ul>\n\u003Ch2 id=\"复盘--下周衔接\">复盘 / 下周衔接\u003C/h2>\n\u003Cul>\n\u003Cli>\u003C/li>\n\u003C/ul>",{"headings":219,"localImagePaths":224,"remoteImagePaths":225,"frontmatter":226,"imagePaths":229},[220,221,222,223],{"depth":30,"slug":185,"text":185},{"depth":30,"slug":187,"text":187},{"depth":30,"slug":189,"text":189},{"depth":30,"slug":191,"text":192},[],[],{"title":202,"week":203,"status":204,"summary":205,"goals":227,"review":228,"draft":52},[207,208,209],[211,212],[]]
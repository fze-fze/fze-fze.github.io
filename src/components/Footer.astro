---
import { withBase } from "../data/site";

const contactLinks = [
  { name: "X", href: "https://x.com/", icon: withBase("/images/X.png"), tone: "original" },
  { name: "Bilibili", href: "https://www.bilibili.com/", icon: withBase("/images/bilibili.png") },
  { name: "GitHub", href: "https://github.com/", icon: withBase("/images/github.png") },
  { name: "Gmail", href: "https://mail.google.com/", icon: withBase("/images/gmail.png") }
];
---

<footer class="site-footer">
  <div class="container footer-shell">
    <nav class="contact-list" aria-label="联系方式">
      {contactLinks.map((item) => (
        <a class="contact-link" href={item.href} aria-label={item.name} target="_blank" rel="noreferrer">
          <img
            class:list={[
              "contact-icon",
              item.tone === "original" && "is-original",
              item.tone === "soft-monochrome" && "is-soft-monochrome"
            ]}
            src={item.icon}
            alt=""
            width="18"
            height="18"
            loading="lazy"
          />
        </a>
      ))}
    </nav>

    <a class="footer-mark" href={withBase("/")}>
      <span class="footer-mark-rule" aria-hidden="true"></span>
      <span class="footer-mark-text">fze's journal</span>
      <span class="footer-mark-rule" aria-hidden="true"></span>
    </a>

    <div class="footer-location" aria-label="当前地址">
      <span class="location-dot" aria-hidden="true"></span>
      <span>中国</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    padding: 1.8rem 0 2.6rem;
  }

  .footer-shell {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 72px;
    padding-top: 1rem;
    border-top: 1px solid var(--line);
  }

  .contact-list {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: nowrap;
  }

  .contact-link {
    width: auto;
    height: auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.2rem;
    transition: transform var(--transition), opacity var(--transition);
    flex: 0 0 auto;
  }

  .contact-link:hover,
  .contact-link:focus-visible {
    transform: translateY(-1px);
    opacity: 0.62;
  }

  .contact-icon {
    width: 20px;
    height: 20px;
    object-fit: contain;
    display: block;
    filter: grayscale(1) brightness(0) saturate(0);
    opacity: 0.82;
  }

  .contact-icon.is-original {
    filter: none;
    opacity: 1;
  }

  .footer-mark {
    position: absolute;
    left: 50%;
    top: calc(50% + 0.5rem);
    transform: translate(-50%, -50%);
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    color: #161616;
    white-space: nowrap;
  }

  .footer-mark-text {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: -0.04em;
    text-transform: lowercase;
  }

  .footer-mark-rule {
    width: 1.8rem;
    height: 1px;
    background: var(--line-strong);
  }

  .footer-location {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    min-height: auto;
    padding: 0;
    border-radius: 999px;
    border: none;
    background: transparent;
    color: #1a1a1a;
    font-weight: 600;
    letter-spacing: -0.02em;
    flex: 0 0 auto;
    font-size: 0.95rem;
  }

  .location-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background: #111;
    opacity: 0.8;
  }

  @media (max-width: 900px) {
    .footer-shell {
      display: grid;
      justify-items: center;
      gap: 1rem;
      min-height: auto;
    }

    .footer-mark {
      position: static;
      transform: none;
      order: 1;
    }

    .contact-list {
      order: 2;
      flex-wrap: wrap;
      justify-content: center;
    }

    .footer-location {
      order: 3;
    }
  }
</style>

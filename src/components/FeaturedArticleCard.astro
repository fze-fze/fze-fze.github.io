---
interface Props {
  href: string;
  title: string;
  description: string;
  dateLabel: string;
  tags?: string[];
}

const { href, title, description, dateLabel, tags = [] } = Astro.props;
---

<article class="feature-card">
  <a class="feature-link" href={href}>
    <div class="feature-art">
      <div class="feature-frame"></div>
      <div class="feature-lines feature-lines-a"></div>
      <div class="feature-lines feature-lines-b"></div>
      <div class="feature-corner feature-corner-a"></div>
      <div class="feature-corner feature-corner-b"></div>

      <div class="feature-body">
        <div class="feature-meta">
          <span>{dateLabel}</span>
          {tags[0] && <span>{tags[0]}</span>}
        </div>
        <h3>{title}</h3>
        <p>{description}</p>
      </div>
    </div>
  </a>
</article>

<style>
  .feature-card {
    align-self: start;
  }

  .feature-link {
    display: grid;
    color: inherit;
  }

  .feature-art {
    position: relative;
    min-height: 25rem;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 30px;
    background: #fff;
    background:
      linear-gradient(180deg, #ffffff, #fafafa);
    display: grid;
    align-content: end;
  }

  .feature-art::before,
  .feature-art::after {
    content: "";
    position: absolute;
    inset: auto;
    border-radius: 999px;
    border: 1px solid rgba(17, 17, 17, 0.08);
  }

  .feature-art::before {
    width: 44%;
    height: 58%;
    left: 10%;
    top: 14%;
  }

  .feature-art::after {
    width: 28%;
    height: 36%;
    right: 12%;
    bottom: 12%;
  }

  .feature-frame {
    position: absolute;
    inset: 1rem;
    border-radius: 24px;
    border: 1px solid rgba(17, 17, 17, 0.06);
  }

  .feature-lines {
    position: absolute;
    height: 1px;
    background: rgba(17, 17, 17, 0.08);
  }

  .feature-lines-a {
    width: 28%;
    left: 8%;
    top: 18%;
  }

  .feature-lines-b {
    width: 34%;
    right: 10%;
    bottom: 20%;
  }

  .feature-corner {
    position: absolute;
    border-radius: 999px;
    background: rgba(17, 17, 17, 0.03);
  }

  .feature-corner-a {
    width: 8rem;
    height: 8rem;
    right: 18%;
    top: 18%;
  }

  .feature-corner-b {
    width: 12rem;
    height: 12rem;
    left: 16%;
    bottom: 10%;
  }

  .feature-body {
    display: grid;
    gap: 0.8rem;
    position: relative;
    z-index: 2;
    padding: 1.35rem 1.45rem 1.55rem;
    border-top: 1px solid rgba(17, 17, 17, 0.06);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.86), #ffffff 62%);
  }

  .feature-body h3,
  .feature-body p {
    margin: 0;
  }

  .feature-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    color: var(--text-soft);
    font-size: 0.96rem;
  }

  .feature-body h3 {
    font-size: clamp(2.3rem, 1.75rem + 1.55vw, 3.55rem);
    line-height: 1;
    letter-spacing: -0.065em;
    text-wrap: balance;
  }

  .feature-body p {
    color: var(--text-soft);
    font-size: 1rem;
    max-width: 42rem;
  }

  @media (max-width: 900px) {
    .feature-art {
      min-height: 21rem;
    }
  }
</style>

---
interface Props {
  href: string;
  title: string;
  dateLabel: string;
  tags?: string[];
  style?: string;
}

const { href, title, dateLabel, tags = [], style } = Astro.props;
---

<article class="rail-card" style={style}>
  <a class="rail-link" href={href}>
    <div class="rail-art">
      <div class="rail-frame"></div>
      <div class="rail-node"></div>
      <div class="rail-line rail-line-a"></div>
      <div class="rail-line rail-line-b"></div>

      <div class="rail-body">
        <h3>{title}</h3>
        <div class="rail-meta">
          {tags[0] && <span>{tags[0]}</span>}
          <span>{dateLabel}</span>
        </div>
      </div>
    </div>
  </a>
</article>

<style>
  .rail-card {
    position: relative;
  }

  .rail-link {
    display: grid;
    gap: 0.9rem;
    color: inherit;
  }

  .rail-art {
    min-height: 15.5rem;
    position: relative;
    overflow: hidden;
    border-radius: 22px;
    border: 1px solid var(--line);
    background: linear-gradient(180deg, #ffffff, #fafafa);
    display: grid;
    align-content: end;
  }

  .rail-frame {
    position: absolute;
    inset: 0.9rem;
    border-radius: 18px;
    border: 1px solid rgba(17, 17, 17, 0.05);
  }

  .rail-node {
    position: absolute;
    width: 3.9rem;
    height: 3.9rem;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    border-radius: 1.35rem;
    border: 1px solid rgba(17, 17, 17, 0.08);
    background: rgba(17, 17, 17, 0.03);
  }

  .rail-line {
    position: absolute;
    height: 1px;
    background: rgba(17, 17, 17, 0.08);
  }

  .rail-line-a {
    width: 38%;
    left: 12%;
    top: 28%;
  }

  .rail-line-b {
    width: 32%;
    right: 12%;
    bottom: 24%;
  }

  .rail-body {
    display: grid;
    gap: 0.5rem;
    position: relative;
    z-index: 2;
    padding: 1rem 1.05rem 1.1rem;
    border-top: 1px solid rgba(17, 17, 17, 0.06);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.88), #ffffff 64%);
  }

  .rail-body h3,
  .rail-meta {
    margin: 0;
  }

  .rail-body h3 {
    font-size: 1.55rem;
    line-height: 1.05;
    letter-spacing: -0.05em;
  }

  .rail-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    color: var(--text-soft);
    font-size: 0.95rem;
  }
</style>

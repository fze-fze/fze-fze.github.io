---
import { withBase } from "../data/site";
---

<section class="hero container">
  <div class="hero-copy">
    <div class="hero-avatar fade-in" aria-hidden="true">
      <span class="hero-avatar-ring"></span>
      <img src={withBase("/images/download.png")} alt="" width="136" height="136" loading="eager" />
    </div>
    <h1 class="fade-in-delay">
      <span class="hero-title" data-typewriter-text="welcome to fze's journal">welcome to fze's journal</span>
    </h1>
    <p class="hero-text fade-in-delay">
      Life is better when<br />
      nobody knows what you are doing.
    </p>
  </div>
</section>

<script is:inline>
  const heroTitle = document.querySelector(".hero-title");
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

  if (heroTitle instanceof HTMLElement && !prefersReducedMotion.matches) {
    const fullText = heroTitle.dataset.typewriterText ?? heroTitle.textContent ?? "";
    let index = 0;

    heroTitle.textContent = "";
    heroTitle.classList.add("is-typing");

    const typeNext = () => {
      if (index < fullText.length) {
        heroTitle.textContent += fullText[index];
        index += 1;
        window.setTimeout(typeNext, index === 1 ? 220 : 82);
        return;
      }

      heroTitle.classList.remove("is-typing");
    };

    window.setTimeout(typeNext, 280);
  }
</script>

<style>
  .hero {
    height: calc(100svh - 6.9rem + 7rem);
    min-height: 760px;
    max-height: 920px;
    display: grid;
    align-items: center;
    padding: clamp(0.75rem, 2vw, 1.5rem) 0 0;
    overflow: clip;
  }

  .hero-copy {
    display: grid;
    gap: 1.2rem;
    max-width: 52rem;
    margin: 0 auto;
    text-align: center;
    justify-items: center;
    transform: translateY(clamp(-5.25rem, -7vw, -2.75rem));
  }

  .hero-avatar {
    position: relative;
    width: 164px;
    height: 164px;
    margin: 0 auto 0.5rem;
    display: grid;
    place-items: center;
    border-radius: 999px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.88), rgba(244, 244, 244, 0.82)),
      radial-gradient(circle at 30% 25%, rgba(255, 255, 255, 0.95), transparent 38%),
      radial-gradient(circle at 70% 75%, rgba(230, 230, 230, 0.7), transparent 42%);
    border: 1px solid rgba(255, 255, 255, 0.92);
    box-shadow:
      0 18px 44px rgba(17, 17, 17, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.95);
    overflow: hidden;
  }

  .hero-avatar-ring {
    position: absolute;
    inset: 10px;
    border-radius: 999px;
    border: 1px solid rgba(17, 17, 17, 0.08);
    pointer-events: none;
  }

  .hero-avatar::before {
    content: "";
    position: absolute;
    top: 12px;
    left: 18px;
    right: 18px;
    height: 44%;
    border-radius: 999px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.7), transparent);
    pointer-events: none;
  }

  .hero-avatar img {
    width: 118px;
    height: 118px;
    object-fit: cover;
    border-radius: 999px;
    filter: grayscale(1) contrast(1.1) brightness(0.96);
  }

  .hero h1 {
    margin: 0 auto;
    max-width: 18ch;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: clamp(1.95rem, 1.35rem + 2.1vw, 3.75rem);
    line-height: 1.02;
    letter-spacing: -0.05em;
    text-transform: none;
    font-weight: 700;
  }

  .hero-title {
    position: relative;
    display: inline;
  }

  .hero-title.is-typing::after {
    content: "";
    display: inline-block;
    width: 0.09em;
    height: 0.92em;
    margin-left: 0.14em;
    vertical-align: -0.06em;
    background: currentColor;
    animation: hero-caret-blink 900ms steps(1, end) infinite;
  }

  .hero-text {
    margin: 0 auto;
    max-width: 34rem;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    color: #8a8a8a;
    font-size: clamp(0.96rem, 0.88rem + 0.22vw, 1.08rem);
    line-height: 1.9;
    letter-spacing: -0.03em;
    text-align: center;
  }

  @media (max-width: 720px) {
    .hero {
      height: calc(100svh - 5.8rem + 4rem);
      min-height: 680px;
      max-height: none;
      padding-top: 0.75rem;
    }

    .hero-copy {
      transform: translateY(-1.5rem);
    }

    .hero-avatar {
      width: 138px;
      height: 138px;
    }

    .hero-avatar img {
      width: 98px;
      height: 98px;
    }
  }

  @keyframes hero-caret-blink {
    0%,
    45% {
      opacity: 1;
    }

    46%,
    100% {
      opacity: 0;
    }
  }
</style>

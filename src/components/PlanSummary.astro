---
interface Props {
  href: string;
  title: string;
  week: string;
  summary: string;
  status: string;
  goals?: string[];
}

const { href, title, week, summary, status, goals = [] } = Astro.props;
const statusLabel = {
  planned: "准备中",
  active: "进行中",
  done: "已完成"
}[status as "planned" | "active" | "done"];
---

<a class="plan-summary" href={href}>
  <div class="plan-top">
    <p>{week}</p>
    <span>{statusLabel}</span>
  </div>
  <h3>{title}</h3>
  <p>{summary}</p>
  <ul>
    {goals.slice(0, 3).map((goal) => <li>{goal}</li>)}
  </ul>
</a>

<style>
  .plan-summary {
    display: grid;
    gap: 0.9rem;
    padding: 1.3rem;
    border-radius: 22px;
    background: var(--panel);
    border: 1px solid var(--line);
    transition: background var(--transition), border-color var(--transition);
  }

  .plan-summary:hover,
  .plan-summary:focus-visible {
    border-color: var(--line-strong);
    background: var(--panel-soft);
  }

  .plan-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    color: var(--text-soft);
  }

  .plan-top p,
  .plan-top span,
  .plan-summary h3,
  .plan-summary p {
    margin: 0;
  }

  .plan-summary h3 {
    font-size: 1.2rem;
    line-height: 1.2;
    font-weight: 650;
    letter-spacing: -0.02em;
  }

  .plan-top span {
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: var(--bg-elevated);
  }

  .plan-summary p,
  .plan-summary ul {
    color: var(--text-soft);
  }

  .plan-summary ul {
    margin: 0;
    padding-left: 1rem;
  }
</style>

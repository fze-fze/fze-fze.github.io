---
interface Props {
  href: string;
  title: string;
  week?: string;
  summary?: string;
  summaryLines?: string[];
  status: string;
}

const { href, title, week, summary, summaryLines = [], status } = Astro.props;
const statusLabel = {
  planned: "准备中",
  active: "进行中",
  done: "已完成"
}[status as "planned" | "active" | "done"];
---

<a class="plan-summary" href={href}>
  <div class="plan-top">
    <p>{week ?? "Week XX"}</p>
    <div class="plan-badges">
      <span>{statusLabel}</span>
    </div>
  </div>
  <h3>{title}</h3>
  {summaryLines.length > 0 ? (
    <div class="plan-copy">
      {summaryLines.map((line) => <p>{line}</p>)}
    </div>
  ) : (
    summary && <p>{summary}</p>
  )}
</a>

<style>
  .plan-summary {
    display: grid;
    gap: 0.9rem;
    padding: 1.3rem;
    border-radius: 22px;
    background: var(--panel);
    border: 1px solid var(--line);
    transition: background var(--transition), border-color var(--transition);
  }

  .plan-summary:hover,
  .plan-summary:focus-visible {
    border-color: var(--line-strong);
    background: var(--panel-soft);
  }

  .plan-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    color: var(--text-soft);
  }

  .plan-badges {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.5rem;
  }

  .plan-top p,
  .plan-top span,
  .plan-summary h3,
  .plan-summary p {
    margin: 0;
  }

  .plan-summary h3 {
    font-size: 1.05rem;
    line-height: 1.24;
    font-weight: 650;
    letter-spacing: -0.02em;
  }

  .plan-top span {
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: var(--bg-elevated);
  }

  .plan-copy {
    display: grid;
    gap: 0.75rem;
  }

  .plan-summary p {
    color: var(--text-soft);
  }
</style>

---
import { type CollectionEntry, getCollection, render } from "astro:content";
import PostLayout from "../../layouts/PostLayout.astro";

export async function getStaticPaths() {
  const plans = await getCollection("plans", ({ data }) => !data.draft);
  return plans.map((plan) => ({
    params: { slug: plan.slug },
    props: { plan }
  }));
}

interface Props {
  plan: CollectionEntry<"plans">;
}

const { plan } = Astro.props;
const { Content } = await render(plan);

const statusLabel = {
  planned: "准备中",
  active: "进行中",
  done: "已完成"
}[plan.data.status];
---

<PostLayout
  title={plan.data.title}
  description={plan.data.summary}
  dateLabel={plan.data.week}
  meta={[statusLabel]}
>
  <Content />
</PostLayout>

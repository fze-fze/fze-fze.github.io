---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { withBase } from "../../data/site";
import SectionShell from "../../components/SectionShell.astro";
import PlanSummary from "../../components/PlanSummary.astro";

const plans = (await getCollection("plans", ({ data }) => !data.draft)).sort((a, b) =>
  b.slug.localeCompare(a.slug)
);
---

<BaseLayout title="每周计划 | fze's journal" description="公开周计划与周复盘归档。">
  <section class="listing">
    <SectionShell title="每周计划" />
    <div class="container archive-grid">
      {plans.map((plan) => (
        <PlanSummary
          href={withBase(`/plans/${plan.slug}`)}
          title={plan.data.title}
          week={plan.data.week}
          summary={plan.data.summary}
          status={plan.data.status}
          goals={plan.data.goals}
        />
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .listing {
    padding: clamp(3rem, 8vw, 6rem) 0 4rem;
  }

  .archive-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  @media (max-width: 900px) {
    .archive-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

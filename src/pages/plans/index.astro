---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { withBase } from "../../data/site";
import SectionShell from "../../components/SectionShell.astro";
import PlanSummary from "../../components/PlanSummary.astro";
import HabitCheckin from "../../components/HabitCheckin.astro";
import { sleepCheckins } from "../../data/sleepCheckins";
import { mindfulnessCheckins } from "../../data/mindfulnessCheckins";
import { sortPlans } from "../../utils/content";

const plans = sortPlans(await getCollection("plans", ({ data }) => !data.draft));

const extractPlanSummary = (body: string, title: string) => {
  const lines = body
    .split("\n")
    .map((line) => line.trim())
    .filter(Boolean);

  let inGoalSection = false;

  for (const line of lines) {
    if (line.startsWith("## ")) {
      inGoalSection = line.includes("本周目标");
      continue;
    }

    if (!inGoalSection) continue;
    if (line.startsWith("- ") || line.startsWith("* ") || /^\d+\./.test(line)) continue;
    return line;
  }

  return `${title} 的公开记录。`;
};
---

<BaseLayout title="计划 | fze's journal" description="月度打卡与每周计划归档。">
  <section class="listing">
    <div class="container habit-grid">
      <HabitCheckin title="早睡打卡" records={sleepCheckins} />
      <HabitCheckin title="正念打卡" records={mindfulnessCheckins} />
    </div>
    <SectionShell title="每周计划" />
    <div class="container archive-grid">
      {plans.map((plan) => (
        <PlanSummary
          href={withBase(`/plans/${plan.slug}`)}
          title={plan.data.title}
          week={plan.data.week}
          summary={extractPlanSummary(plan.body, plan.data.title)}
          status={plan.data.status}
        />
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .listing {
    padding: clamp(3rem, 8vw, 6rem) 0 4rem;
  }

  .archive-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .habit-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    column-gap: 3.2rem;
    row-gap: 1rem;
    margin-bottom: clamp(2.5rem, 6vw, 4rem);
  }

  .habit-grid > * {
    min-width: 0;
    width: 100%;
  }

  @media (max-width: 900px) {
    .habit-grid {
      grid-template-columns: 1fr;
    }

    .archive-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { withBase } from "../../data/site";
import SectionShell from "../../components/SectionShell.astro";
import ArticleSummary from "../../components/ArticleSummary.astro";

const essays = (await getCollection("essays", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<BaseLayout title="随笔 | fze's journal" description="按时间归档的随笔列表。">
  <section class="listing">
    <SectionShell title="随笔" />
    <div class="container archive-grid">
      {essays.map((essay) => (
        <ArticleSummary
          href={withBase(`/essays/${essay.slug}`)}
          title={essay.data.title}
          description={essay.data.description}
          dateLabel={essay.data.date.toLocaleDateString("zh-CN")}
          tags={essay.data.tags}
        />
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .listing {
    padding: clamp(3rem, 8vw, 6rem) 0 4rem;
  }

  .archive-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  @media (max-width: 900px) {
    .archive-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import HomeHero from "../components/HomeHero.astro";
import ArticlePreviewCard from "../components/ArticlePreviewCard.astro";
import HabitCheckin from "../components/HabitCheckin.astro";
import { withBase } from "../data/site";
import { sleepCheckins } from "../data/sleepCheckins";
import { mindfulnessCheckins } from "../data/mindfulnessCheckins";
import { sortArticles } from "../utils/content";

const recentArticles = sortArticles(await getCollection("articles", ({ data }) => !data.draft));

const featuredArticle = recentArticles[0];
const railArticles = recentArticles.slice(1, 6);
---

<BaseLayout title="fze's journal | 纯文章静态博客" description="一个只保留文章的极简静态博客。">
  <HomeHero />

  {featuredArticle && (
    <section class="home-section recent-articles-section">
      <div class="container article-story-grid">
        <div class="article-story-main">
          <div class="article-story-sticky">
            <ArticlePreviewCard
              href={withBase(`/articles/${featuredArticle.slug}`)}
              title={featuredArticle.data.title}
              description={featuredArticle.data.description}
              dateLabel={featuredArticle.data.date.toLocaleDateString("zh-CN")}
              tags={featuredArticle.data.tags}
              cover={featuredArticle.data.cover}
              variant="hero"
              hideMetaTag={true}
            />
          </div>
        </div>

        <aside class="article-story-rail" aria-label="更多最近文章">
          {railArticles.map((article) => (
            <ArticlePreviewCard
              href={withBase(`/articles/${article.slug}`)}
              title={article.data.title}
              description={article.data.description}
              dateLabel={article.data.date.toLocaleDateString("zh-CN")}
              tags={article.data.tags}
              cover={article.data.cover}
              variant="compact"
            />
          ))}
          <a class="article-archive-link" href={withBase("/articles")}>
            <span>浏览全部文章</span>
            <span aria-hidden="true">→</span>
          </a>
        </aside>
      </div>
    </section>
  )}

  <section class="home-section habit-section">
    <div class="container habit-grid">
      <HabitCheckin title="早睡" records={sleepCheckins} />
      <HabitCheckin title="冥想" records={mindfulnessCheckins} />
    </div>
  </section>
</BaseLayout>

<style>
  .home-section {
    padding: 0 0 clamp(5.5rem, 11vw, 8.5rem);
  }

  .article-story-grid {
    display: grid;
    gap: 1rem;
  }

  .recent-articles-section {
    margin-top: clamp(1rem, 2vw, 1.75rem);
  }

  .habit-section {
    padding-top: 0;
  }

  .article-story-grid {
    grid-template-columns: minmax(0, 1.7fr) minmax(280px, 0.6fr);
    align-items: start;
    gap: 2rem;
  }

  .article-story-main,
  .article-story-rail {
    min-width: 0;
  }

  .article-story-main {
    align-self: stretch;
  }

  .article-story-sticky {
    position: sticky;
    top: var(--sticky-top);
    align-self: start;
  }

  .article-story-rail {
    display: grid;
    gap: 1rem;
    align-content: start;
  }

  .article-archive-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.15rem;
    border-radius: 22px;
    border: 1px solid var(--line);
    background: var(--bg-elevated);
    transition: background var(--transition), border-color var(--transition);
  }

  .article-archive-link:hover,
  .article-archive-link:focus-visible {
    background: var(--panel-soft);
    border-color: var(--line-strong);
  }

  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 1.5rem;
  }

  .section-head-link {
    color: var(--text-soft);
    font-size: 0.96rem;
  }

  .habit-grid {
    display: flex;
    gap: 3.2rem;
    align-items: stretch;
    flex-wrap: wrap;
  }

  .habit-grid > * {
    flex: 1 1 320px;
    min-width: 0;
  }

  @media (max-width: 900px) {
    .article-story-grid {
      grid-template-columns: 1fr;
    }

    .article-story-sticky {
      position: static;
    }

    .habit-grid {
      gap: 1rem;
    }
  }
</style>

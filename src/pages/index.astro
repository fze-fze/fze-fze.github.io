---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import HomeHero from "../components/HomeHero.astro";
import SectionShell from "../components/SectionShell.astro";
import StickySection from "../components/StickySection.astro";
import FeaturedArticleCard from "../components/FeaturedArticleCard.astro";
import RailArticleCard from "../components/RailArticleCard.astro";
import PlanSummary from "../components/PlanSummary.astro";

const allArticles = (await getCollection("articles", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const featuredArticle = allArticles[0];
const railArticles = allArticles.slice(1, 4);

const latestPlan = (await getCollection("plans", ({ data }) => !data.draft))
  .sort((a, b) => b.slug.localeCompare(a.slug))[0];
---

<BaseLayout title="fze's journal | 极简静态博客" description="首页、文章和每周计划统一于同一套白底黑字的极简视觉系统。">
  <HomeHero />

  <StickySection sectionHeight="220svh" stickyTop="var(--sticky-top)" className="article-story-section">
    {featuredArticle && (
      <div class="container story-shell">
        <div class="story-grid">
          <div class="story-feature-column">
            <FeaturedArticleCard
              href={`/articles/${featuredArticle.slug}`}
              title={featuredArticle.data.title}
              description={featuredArticle.data.description}
              dateLabel={featuredArticle.data.date.toLocaleDateString("zh-CN")}
              tags={featuredArticle.data.tags}
            />
          </div>

          <div class="story-rail">
            {railArticles.map((article, index) => (
              <RailArticleCard
                href={`/articles/${article.slug}`}
                title={article.data.title}
                dateLabel={article.data.date.toLocaleDateString("zh-CN")}
                tags={article.data.tags}
                style={`--rail-index:${index};`}
              />
            ))}
          </div>
        </div>
      </div>
    )}
  </StickySection>

  <section class="home-section">
    <SectionShell
      title="本周计划"
      copy="保留一周的目标、推进和复盘，不做复杂看板，只做足够清楚的公开记录。"
    />
    <div class="container plan-wrap">
      {latestPlan && (
        <PlanSummary
          href={`/plans/${latestPlan.slug}`}
          title={latestPlan.data.title}
          week={latestPlan.data.week}
          summary={latestPlan.data.summary}
          status={latestPlan.data.status}
          goals={latestPlan.data.goals}
        />
      )}
      <div class="notes-panel">
        <h3>内容方向</h3>
        <p>
          这里适合放产品思考、开发日志、设计记录，以及每周对自己节奏的校准。表达尽量克制，重点交还给内容。
        </p>
        <a class="surface-link" href="/plans">
          查看完整计划归档
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <section class="home-section about-section">
    <SectionShell
      title="一个更容易长期维护的博客结构"
      copy="文章与计划分开管理，界面和内容解耦。你只需要持续写 Markdown，站点负责组织和生成。"
    />
    <div class="container about-grid">
      <div class="about-copy">
        <p>内容层使用 Astro Content Collections 做校验，减少 frontmatter 漏填问题。</p>
        <p>表现层用统一布局和 design tokens 管理，让首页、文章、计划天然保持同一种语言。</p>
      </div>
      <div class="about-links">
        <a class="surface-link" href="/articles">浏览全部文章 <span aria-hidden="true">→</span></a>
        <a class="surface-link" href="/plans">浏览每周计划 <span aria-hidden="true">→</span></a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .home-section {
    padding: 0 0 clamp(2.5rem, 6vw, 5rem);
  }

  .article-story-section {
    margin-top: clamp(1rem, 2vw, 1.75rem);
  }

  .story-grid,
  .plan-wrap,
  .about-grid {
    display: grid;
    gap: 1rem;
  }

  .story-shell {
    display: grid;
    align-items: center;
    min-height: calc(100svh - var(--sticky-top));
    padding-bottom: clamp(0.25rem, 1vw, 0.75rem);
  }

  .story-grid {
    grid-template-columns: minmax(0, 1.65fr) minmax(290px, 0.55fr);
    align-items: start;
    gap: 2rem;
  }

  .story-feature-column {
    transform:
      translate3d(
        0,
        calc(var(--section-progress) * -1.1rem),
        0
      )
      scale(calc(1 - var(--section-progress) * 0.02));
    transform-origin: center top;
    opacity: calc(1 - var(--section-progress) * 0.08);
    transition: transform 120ms linear, opacity 120ms linear;
    will-change: transform, opacity;
  }

  .story-rail {
    position: relative;
    min-height: 40rem;
  }

  .story-rail :global(.rail-card) {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    transform:
      translate3d(
        0,
        calc(
          var(--rail-index) * 16.25rem - var(--section-progress) * 31rem
        ),
        0
      )
      scale(calc(1 - var(--rail-index) * 0.03));
    opacity: clamp(
      0.24,
      calc(1.02 - var(--rail-index) * 0.08 - var(--section-progress) * 0.04),
      1
    );
    transition: transform 120ms linear, opacity 120ms linear;
    will-change: transform, opacity;
  }

  .plan-wrap {
    grid-template-columns: minmax(0, 1.25fr) minmax(280px, 0.75fr);
  }

  .notes-panel,
  .about-copy,
  .about-links {
    border-radius: 22px;
    padding: 1.35rem;
    background: var(--panel);
    border: 1px solid var(--line);
  }

  .notes-panel {
    display: grid;
    align-content: start;
    gap: 1rem;
  }

  .notes-panel h3,
  .notes-panel p {
    margin: 0;
  }

  .about-grid {
    grid-template-columns: 1.1fr 0.9fr;
  }

  .about-copy {
    display: grid;
    gap: 1rem;
  }

  .about-copy p {
    margin: 0;
  }

  .about-links {
    display: grid;
    gap: 0.8rem;
  }

  @media (max-width: 900px) {
    .story-shell {
      min-height: auto;
      align-items: start;
    }

    .story-feature-column {
      transform: none;
      opacity: 1;
    }

    .story-grid,
    .plan-wrap,
    .about-grid {
      grid-template-columns: 1fr;
    }

    .story-rail {
      min-height: auto;
      display: grid;
      gap: 1rem;
    }

    .story-rail :global(.rail-card) {
      position: static;
      transform: none;
      opacity: 1;
    }
  }
</style>

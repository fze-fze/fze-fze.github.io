---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import HomeHero from "../components/HomeHero.astro";
import SectionShell from "../components/SectionShell.astro";
import ArticlePreviewCard from "../components/ArticlePreviewCard.astro";
import EssayListCard from "../components/EssayListCard.astro";
import PlanSummary from "../components/PlanSummary.astro";
import { withBase } from "../data/site";
import { getCurrentPlan, sortArticles } from "../utils/content";

const recentArticles = sortArticles(await getCollection("articles", ({ data }) => !data.draft));

const featuredArticle = recentArticles[0];
const railArticles = recentArticles.slice(1, 4);
const recentEssays = (await getCollection("essays", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 4);

const currentPlan = getCurrentPlan(await getCollection("plans", ({ data }) => !data.draft));

const extractPlanSectionLines = (body?: string) => {
  if (!body) return [];

  const lines = body
    .split("\n")
    .map((line) => line.trim());

  let inGoalSection = false;
  const sectionLines: string[] = [];

  for (const line of lines) {
    if (line.startsWith("## ")) {
      if (inGoalSection) break;
      inGoalSection = line.includes("本周目标");
      continue;
    }

    if (!inGoalSection) continue;
    if (!line) continue;
    sectionLines.push(line);
  }

  return sectionLines;
};
---

<BaseLayout title="fze's journal | 极简静态博客" description="首页、文章和每周计划统一于同一套白底黑字的极简视觉系统。">
  <HomeHero />

  {featuredArticle && (
    <section class="home-section recent-articles-section">
      <SectionShell title="最近文章" />
      <div class="container article-story-grid">
        <div class="article-story-main">
          <div class="article-story-sticky">
            <ArticlePreviewCard
              href={withBase(`/articles/${featuredArticle.slug}`)}
              title={featuredArticle.data.title}
              description={featuredArticle.data.description}
              dateLabel={featuredArticle.data.date.toLocaleDateString("zh-CN")}
              tags={featuredArticle.data.tags}
              cover={featuredArticle.data.cover}
              variant="hero"
              hideMetaTag={true}
            />
          </div>
        </div>

        <aside class="article-story-rail" aria-label="更多最近文章">
          {railArticles.map((article) => (
            <ArticlePreviewCard
              href={withBase(`/articles/${article.slug}`)}
              title={article.data.title}
              description={article.data.description}
              dateLabel={article.data.date.toLocaleDateString("zh-CN")}
              tags={article.data.tags}
              cover={article.data.cover}
              variant="compact"
            />
          ))}
          <a class="article-archive-link" href={withBase("/articles")}>
            <span>浏览全部文章</span>
            <span aria-hidden="true">→</span>
          </a>
        </aside>
      </div>
    </section>
  )}

  {recentEssays.length > 0 && (
    <section class="home-section recent-essays-section">
      <div class="container section-head">
        <h2 class="section-title">最近随笔</h2>
        <a class="section-head-link" href={withBase("/essays")}>查看更多</a>
      </div>
      <div class="container essays-grid">
        {recentEssays.map((essay) => (
          <EssayListCard
            href={withBase(`/essays/${essay.slug}`)}
            title={essay.data.title}
            dateLabel={essay.data.date.toLocaleDateString("zh-CN")}
            cover={essay.data.cover}
          />
        ))}
      </div>
    </section>
  )}

  <section class="home-section">
    <div class="container section-head">
      <h2 class="section-title">本周计划</h2>
      <a class="section-head-link" href={withBase("/plans")}>查看更多</a>
    </div>
    <div class="container plan-wrap">
      {currentPlan && (
        <PlanSummary
          href={withBase(`/plans/${currentPlan.slug}`)}
          title={currentPlan.data.title}
          week={currentPlan.data.week}
          summaryLines={extractPlanSectionLines(currentPlan.body)}
          status={currentPlan.data.status}
        />
      )}
      <div class="notes-panel">
        <div class="notes-panel-head">
          <h3>Todo List</h3>
        </div>
        <ul class="todo-list">
          {(currentPlan?.data.goal ?? []).slice(0, 4).map((item) => (
            <li class:list={{ "is-done": item.done }}>
              <span class="todo-check" aria-hidden="true"></span>
              <span>{item.text}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .home-section {
    padding: 0 0 clamp(5.5rem, 11vw, 8.5rem);
  }

  .article-story-grid,
  .essays-grid,
  .plan-wrap {
    display: grid;
    gap: 1rem;
  }

  .recent-articles-section {
    margin-top: clamp(1rem, 2vw, 1.75rem);
  }

  .article-story-grid {
    grid-template-columns: minmax(0, 1.7fr) minmax(280px, 0.6fr);
    align-items: start;
    gap: 2rem;
  }

  .article-story-main,
  .article-story-rail {
    min-width: 0;
  }

  .article-story-main {
    align-self: stretch;
  }

  .article-story-sticky {
    position: sticky;
    top: var(--sticky-top);
    align-self: start;
  }

  .article-story-rail {
    display: grid;
    gap: 1rem;
    align-content: start;
  }

  .article-archive-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.15rem;
    border-radius: 22px;
    border: 1px solid var(--line);
    background: var(--bg-elevated);
    transition: background var(--transition), border-color var(--transition);
  }

  .article-archive-link:hover,
  .article-archive-link:focus-visible {
    background: var(--panel-soft);
    border-color: var(--line-strong);
  }

  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 1.5rem;
  }

  .section-head-link {
    color: var(--text-soft);
    font-size: 0.96rem;
  }

  .essays-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    column-gap: 3rem;
    row-gap: 1.5rem;
  }

  .plan-wrap {
    grid-template-columns: minmax(0, 1.25fr) minmax(280px, 0.75fr);
  }

  .notes-panel {
    border-radius: 22px;
    padding: 1.35rem;
    background: var(--panel);
    border: 1px solid var(--line);
  }

  .notes-panel {
    display: grid;
    align-content: start;
    gap: 1rem;
  }

  .notes-panel-head,
  .todo-list li {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.9rem;
  }

  .notes-panel-head h3,
  .todo-list,
  .todo-list li {
    margin: 0;
  }

  .notes-panel-head h3 {
    font-size: 1rem;
    letter-spacing: -0.03em;
  }

  .todo-list {
    display: grid;
    gap: 0.75rem;
    padding: 0;
    list-style: none;
  }

  .todo-list li {
    justify-content: flex-start;
    align-items: flex-start;
    color: var(--text);
    line-height: 1.45;
  }

  .todo-check {
    position: relative;
    width: 1rem;
    height: 1rem;
    flex: 0 0 1rem;
    margin-top: 0.18rem;
    border-radius: 999px;
    border: 1px solid var(--line-strong);
    background: var(--bg-elevated);
  }

  .todo-list li.is-done {
    color: var(--text-soft);
  }

  .todo-list li.is-done .todo-check {
    border-color: #111111;
    background: #111111;
  }

  .todo-list li.is-done .todo-check::after {
    content: "";
    position: absolute;
    left: 0.31rem;
    top: 0.14rem;
    width: 0.22rem;
    height: 0.46rem;
    border-right: 2px solid #ffffff;
    border-bottom: 2px solid #ffffff;
    transform: rotate(45deg);
  }

  .todo-list li.is-done span:last-child {
    text-decoration: line-through;
    text-decoration-thickness: 1px;
  }

  @media (max-width: 900px) {
    .article-story-grid,
    .essays-grid,
    .plan-wrap {
      grid-template-columns: 1fr;
    }

    .article-story-sticky {
      position: static;
    }
  }
</style>

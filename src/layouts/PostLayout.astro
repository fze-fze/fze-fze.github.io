---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description?: string;
  dateLabel?: string;
  meta?: string[];
}

const { title, description, dateLabel, meta = [] } = Astro.props;

const weightedLength = (value: string) =>
  Array.from(value).reduce((sum, char) => sum + (/[\u0000-\u00ff]/.test(char) ? 0.6 : 1), 0);

const semanticBreakPatterns = [
  /为什么/g,
  /是什么/g,
  /意味着/g,
  /值[得]/g,
  /如何/g,
  /以及/g,
  /时代下的/g,
  /之下的/g,
  /中的/g,
  /里的/g,
  /之后/g,
  /之前/g,
  /的/g,
  /，/g,
  /、/g,
  /：/g,
];

const splitTitleIntoTwoLines = (rawTitle: string) => {
  const normalizedTitle = rawTitle.replace(/\s+/g, " ").trim();
  const totalWeight = weightedLength(normalizedTitle);

  if (totalWeight <= 12) {
    return [normalizedTitle];
  }

  const candidates = new Map<number, number>();

  for (const pattern of semanticBreakPatterns) {
    for (const match of normalizedTitle.matchAll(pattern)) {
      const breakpoint = match.index! + match[0].length;
      const left = normalizedTitle.slice(0, breakpoint).trim();
      const right = normalizedTitle.slice(breakpoint).trim();

      if (!left || !right || left.length < 3 || right.length < 2) {
        continue;
      }

      const leftWeight = weightedLength(left);
      const rightWeight = weightedLength(right);
      const balancePenalty = Math.abs(leftWeight - rightWeight);

      let bonus = 0;
      if (/，|、|：$/.test(match[0])) bonus += 2.8;
      if (/为什么|是什么|意味着|如何|以及/.test(match[0])) bonus += 2.4;
      if (/值得/.test(match[0])) bonus += 2.2;
      if (/时代下的|之下的|中的|里的|之后|之前/.test(match[0])) bonus += 1.8;
      if (/的/.test(match[0])) bonus += 0.8;

      const score = balancePenalty - bonus;
      const prev = candidates.get(breakpoint);
      if (prev === undefined || score < prev) {
        candidates.set(breakpoint, score);
      }
    }
  }

  if (candidates.size === 0) {
    return [normalizedTitle];
  }

  const [bestBreakpoint, bestScore] = [...candidates.entries()].sort((a, b) => a[1] - b[1])[0];

  if (bestScore > 4.2 && totalWeight < 18) {
    return [normalizedTitle];
  }

  return [
    normalizedTitle.slice(0, bestBreakpoint).trim(),
    normalizedTitle.slice(bestBreakpoint).trim(),
  ];
};

const titleLines = splitTitleIntoTwoLines(title);
---

<BaseLayout title={`${title} | fze's journal`} description={description}>
  <section class="article-hero container">
    <h1 class:list={["fade-in", { "is-split": titleLines.length > 1 }]}>
      {titleLines.map((line, index) => (
        <span class="title-line">{line}</span>
      ))}
    </h1>
    {description && <p class="fade-in-delay">{description}</p>}
    <ul class="meta-list fade-in-delay">
      {dateLabel && <li class="meta-pill">{dateLabel}</li>}
      {meta.map((item) => <li class="meta-pill">{item}</li>)}
    </ul>
  </section>

  <article class="container article-shell">
    <slot />
  </article>
</BaseLayout>

<script is:inline>
  const articleShell = document.querySelector(".article-shell");

  const formatHost = (hostname) => hostname.replace(/^www\./, "");

  const looksLikeUrlText = (text) => /^https?:\/\//i.test(text);

  const truncateText = (value, maxLength) =>
    value.length > maxLength ? `${value.slice(0, maxLength - 1)}…` : value;

  const deriveTitle = (text, url) => {
    if (text && !looksLikeUrlText(text)) {
      return truncateText(text, 92);
    }

    const fallback = decodeURIComponent(url.pathname.split("/").filter(Boolean).pop() || "")
      .replace(/[-_]+/g, " ")
      .trim();

    if (fallback) {
      return truncateText(fallback, 92);
    }

    return formatHost(url.hostname);
  };

  const deriveBadge = (hostname) =>
    formatHost(hostname)
      .split(".")
      .filter(Boolean)
      .slice(0, 2)
      .map((part) => part[0]?.toUpperCase() ?? "")
      .join("") || "↗";

  const isStandaloneLinkParagraph = (paragraph, anchor) =>
    Array.from(paragraph.childNodes).every((node) => {
      if (node === anchor) return true;
      return node.nodeType === Node.TEXT_NODE && !node.textContent?.trim();
    });

  const enhanceArticleLinks = () => {
    if (!articleShell) return;

    const candidates = articleShell.querySelectorAll("p > a:only-child[href]");

    candidates.forEach((anchor) => {
      if (!(anchor instanceof HTMLAnchorElement)) return;
      if (anchor.dataset.linkCardReady === "true") return;
      if (anchor.closest("li, blockquote")) return;
      if (anchor.querySelector("img, picture, svg, video, iframe")) return;

      const paragraph = anchor.parentElement;
      if (!(paragraph instanceof HTMLParagraphElement)) return;
      if (!isStandaloneLinkParagraph(paragraph, anchor)) return;

      let url;

      try {
        url = new URL(anchor.href, window.location.origin);
      } catch {
        return;
      }

      if (!/^https?:$/.test(url.protocol)) return;

      const rawText = anchor.textContent?.trim() ?? "";
      const host = formatHost(url.hostname);
      const title = deriveTitle(rawText, url);
      const badge = deriveBadge(url.hostname);
      const faviconUrl = `https://www.google.com/s2/favicons?domain=${encodeURIComponent(url.hostname)}&sz=128`;

      paragraph.dataset.linkCard = "true";
      anchor.dataset.linkCardLink = "true";
      anchor.dataset.linkCardReady = "true";
      anchor.setAttribute("aria-label", `${title} - ${host}`);

      anchor.textContent = "";

      const copy = document.createElement("span");
      copy.className = "link-card__copy";

      const eyebrow = document.createElement("span");
      eyebrow.className = "link-card__eyebrow";
      eyebrow.textContent = host;

      const titleNode = document.createElement("strong");
      titleNode.className = "link-card__title";
      titleNode.textContent = title;

      copy.append(eyebrow, titleNode);

      const media = document.createElement("span");
      media.className = "link-card__media";
      media.setAttribute("aria-hidden", "true");

      const faviconNode = document.createElement("img");
      faviconNode.className = "link-card__favicon";
      faviconNode.src = faviconUrl;
      faviconNode.alt = "";
      faviconNode.loading = "lazy";
      faviconNode.referrerPolicy = "no-referrer";

      const badgeNode = document.createElement("span");
      badgeNode.className = "link-card__badge";
      badgeNode.textContent = badge;

      const arrowNode = document.createElement("span");
      arrowNode.className = "link-card__arrow";
      arrowNode.textContent = "↗";

      faviconNode.addEventListener("load", () => {
        media.dataset.hasImage = "true";
      });

      faviconNode.addEventListener("error", () => {
        faviconNode.remove();
      });

      media.append(faviconNode, badgeNode, arrowNode);
      anchor.append(copy, media);
    });
  };

  enhanceArticleLinks();
  document.addEventListener("astro:page-load", enhanceArticleLinks);
</script>

<style>
  .article-hero {
    padding: clamp(3.5rem, 10vw, 6rem) 0 1.5rem;
    display: grid;
    gap: 1rem;
    justify-items: center;
    text-align: center;
  }

  .article-hero h1 {
    margin: 0;
    font-size: clamp(2.7rem, 2rem + 2.4vw, 4.6rem);
    line-height: 1.04;
    letter-spacing: -0.04em;
    width: min(100%, 14ch);
    margin-inline: auto;
    word-break: keep-all;
    overflow-wrap: normal;
  }

  .article-hero h1.is-split {
    width: fit-content;
    max-width: 100%;
  }

  .article-hero .title-line {
    display: block;
  }

  .article-hero h1.is-split .title-line {
    white-space: nowrap;
  }

  .article-hero p {
    margin: 0;
    max-width: 44rem;
    color: var(--text-soft);
    font-size: 1.05rem;
  }

  .article-shell {
    width: min(100%, 56rem);
    border-radius: 24px;
    padding: clamp(1.2rem, 2vw, 1.8rem) clamp(1rem, 3vw, 3rem);
    margin: 0 auto clamp(2.2rem, 5vw, 4rem);
    background: var(--panel);
    border: 1px solid var(--line);
  }

  .article-hero :global(.meta-list) {
    justify-content: center;
  }

  .article-shell :global(h2),
  .article-shell :global(h3) {
    line-height: 1.15;
    margin-top: 2.2rem;
    letter-spacing: -0.03em;
  }

  .article-shell :global(p),
  .article-shell :global(li),
  .article-shell :global(blockquote) {
    color: var(--text);
    font-size: 1.02rem;
    line-height: 1.9;
  }

  .article-shell :global(ul),
  .article-shell :global(ol) {
    padding-left: 1.2rem;
  }

  .article-shell :global(blockquote) {
    margin: 1.6rem 0;
    padding: 1rem 1.2rem;
    border-left: 3px solid #cfcfcf;
    background: var(--bg-elevated);
    border-radius: 14px;
  }

  .article-shell :global(code) {
    font-family: "SFMono-Regular", ui-monospace, monospace;
    font-size: 0.92em;
    background: #f3f3f3;
    padding: 0.15rem 0.4rem;
    border-radius: 8px;
  }

  .article-shell :global(pre) {
    overflow-x: auto;
    padding: 1rem;
    border-radius: 16px;
    background: #f7f7f7;
    border: 1px solid var(--line);
  }

  .article-shell :global(pre code) {
    background: transparent;
    padding: 0;
  }

  .article-shell :global(figure) {
    margin: 2rem auto;
    display: grid;
    justify-items: center;
    gap: 0.8rem;
  }

  .article-shell :global(img) {
    margin: 2rem auto;
  }

  .article-shell :global(figure img) {
    margin: 0 auto;
  }

  .article-shell :global(figcaption) {
    max-width: 42rem;
    color: var(--text-soft);
    font-size: 0.94rem;
    line-height: 1.7;
    text-align: center;
  }

  .article-shell :global(a:not([data-link-card-link])) {
    color: #0f5cc0;
    font-weight: 550;
    text-decoration-line: underline;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.18em;
    text-decoration-color: rgba(15, 92, 192, 0.35);
    transition:
      color var(--transition),
      text-decoration-color var(--transition),
      background-position var(--transition);
    background-image: linear-gradient(rgba(15, 92, 192, 0.12), rgba(15, 92, 192, 0.12));
    background-repeat: no-repeat;
    background-position: 0 100%;
    background-size: 100% 0.42em;
    border-radius: 0.2em;
  }

  .article-shell :global(a:not([data-link-card-link]):hover),
  .article-shell :global(a:not([data-link-card-link]):focus-visible) {
    color: #0a417f;
    text-decoration-color: rgba(10, 65, 127, 0.55);
    background-position: 0 85%;
  }

  .article-shell :global(p[data-link-card]) {
    margin: 1.6rem 0;
  }

  .article-shell :global([data-link-card-link]) {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.05rem 1rem 1.15rem;
    border-radius: 24px;
    border: 1px solid rgba(17, 17, 17, 0.08);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(245, 245, 245, 0.95)),
      var(--panel);
    box-shadow:
      0 10px 26px rgba(17, 17, 17, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.9);
    transition:
      transform var(--transition),
      box-shadow var(--transition),
      border-color var(--transition);
  }

  .article-shell :global([data-link-card-link]:hover),
  .article-shell :global([data-link-card-link]:focus-visible) {
    transform: translateY(-2px);
    border-color: rgba(17, 17, 17, 0.14);
    box-shadow:
      0 16px 38px rgba(17, 17, 17, 0.09),
      inset 0 1px 0 rgba(255, 255, 255, 0.92);
  }

  .article-shell :global(.link-card__copy) {
    min-width: 0;
    display: grid;
    align-content: center;
    gap: 0.38rem;
  }

  .article-shell :global(.link-card__eyebrow) {
    color: var(--text-soft);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .article-shell :global(.link-card__title) {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    color: var(--text);
    font-size: 1rem;
    line-height: 1.4;
    letter-spacing: -0.02em;
  }

  .article-shell :global(.link-card__media) {
    width: clamp(92px, 16vw, 116px);
    min-height: 116px;
    border-radius: 18px;
    background:
      radial-gradient(circle at top right, rgba(255, 255, 255, 0.82), transparent 45%),
      linear-gradient(145deg, #1e1e1e, #434343);
    display: grid;
    align-content: space-between;
    justify-items: start;
    padding: 0.78rem;
    color: #ffffff;
  }

  .article-shell :global(.link-card__favicon) {
    width: 3rem;
    height: 3rem;
    margin: 0;
    object-fit: cover;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 8px 18px rgba(0, 0, 0, 0.14);
  }

  .article-shell :global(.link-card__media[data-has-image="true"] .link-card__badge) {
    display: none;
  }

  .article-shell :global(.link-card__badge) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.5rem;
    min-height: 2.5rem;
    padding: 0.4rem 0.55rem;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.14);
    backdrop-filter: blur(10px);
    font-size: 0.88rem;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  .article-shell :global(.link-card__arrow) {
    justify-self: end;
    font-size: 1rem;
    opacity: 0.88;
  }

  @media (max-width: 720px) {
    .article-shell :global([data-link-card-link]) {
      grid-template-columns: minmax(0, 1fr);
    }

    .article-shell :global(.link-card__media) {
      width: 100%;
      min-height: 82px;
      grid-template-columns: auto auto;
      align-items: end;
      justify-content: space-between;
    }
  }
</style>

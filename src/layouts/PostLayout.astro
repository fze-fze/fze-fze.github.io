---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  dateLabel?: string;
  meta?: string[];
}

const { title, description, dateLabel, meta = [] } = Astro.props;
---

<BaseLayout title={`${title} | fze's journal`} description={description}>
  <section class="article-hero container">
    <h1 class="fade-in">{title}</h1>
    <p class="fade-in-delay">{description}</p>
    <ul class="meta-list fade-in-delay">
      {dateLabel && <li class="meta-pill">{dateLabel}</li>}
      {meta.map((item) => <li class="meta-pill">{item}</li>)}
    </ul>
  </section>

  <article class="container article-shell">
    <slot />
  </article>
</BaseLayout>

<style>
  .article-hero {
    padding: clamp(3.5rem, 10vw, 6rem) 0 1.5rem;
    display: grid;
    gap: 1rem;
  }

  .article-hero h1 {
    margin: 0;
    font-size: clamp(2.7rem, 2rem + 2.4vw, 4.6rem);
    line-height: 1.04;
    letter-spacing: -0.04em;
    max-width: 14ch;
  }

  .article-hero p {
    margin: 0;
    max-width: 44rem;
    color: var(--text-soft);
    font-size: 1.05rem;
  }

  .article-shell {
    border-radius: 24px;
    padding: clamp(1.2rem, 2vw, 1.8rem) clamp(1rem, 3vw, 3rem);
    margin-bottom: clamp(2.2rem, 5vw, 4rem);
    background: var(--panel);
    border: 1px solid var(--line);
  }

  .article-shell :global(h2),
  .article-shell :global(h3) {
    line-height: 1.15;
    margin-top: 2.2rem;
    letter-spacing: -0.03em;
  }

  .article-shell :global(p),
  .article-shell :global(li),
  .article-shell :global(blockquote) {
    color: rgba(236, 236, 236, 0.94);
    font-size: 1.02rem;
  }

  .article-shell :global(ul),
  .article-shell :global(ol) {
    padding-left: 1.2rem;
  }

  .article-shell :global(blockquote) {
    margin: 1.6rem 0;
    padding: 1rem 1.2rem;
    border-left: 3px solid #cfcfcf;
    background: var(--bg-elevated);
    border-radius: 14px;
  }

  .article-shell :global(code) {
    font-family: "SFMono-Regular", ui-monospace, monospace;
    font-size: 0.92em;
    background: #f3f3f3;
    padding: 0.15rem 0.4rem;
    border-radius: 8px;
  }

  .article-shell :global(pre) {
    overflow-x: auto;
    padding: 1rem;
    border-radius: 16px;
    background: #f7f7f7;
    border: 1px solid var(--line);
  }

  .article-shell :global(pre code) {
    background: transparent;
    padding: 0;
  }
</style>
